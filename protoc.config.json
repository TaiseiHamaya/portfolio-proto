{
	"protoc": "./portfolio-proto/protoc-32.1-win64/bin/protoc.exe",
	"protoDir": "./portfolio-proto",
	"targets": [
		{
			"name": "C++ Client",
			"lang": "cpp",
			"out": "./PortfolioGameClient/Game/Scripts/Proto",
			"files": [
				"common/math.proto",
				"common/session.proto",
				"process/gateway/packet.proto",
				"process/network/text.proto",
				"process/db/user/login.proto",
				"process/db/user/logout.proto",
				"process/db/user/signup.proto",
				"process/zone/sync.proto",
				"process/zone/enemy.proto",
				"process/world/player_route.proto",
				"process/lobby/start_game.proto",
				"process/lobby/end_game.proto",
				"process/lobby/enter.proto",
				"process/lobby/exit.proto"
			]
		},
		{
			"name": "Rust Gateway",
			"lang": "rust",
			"out": "./PortfolioGameServer/portfolio-server-gateway/src/network/proto",
			"rustOpt": "experimental-codegen=enabled,kernel=upb",
			"files": [
				"common/math.proto",
				"common/session.proto",
				"process/gateway/packet.proto",
				"process/network/text.proto",
				"process/db/user/login.proto",
				"process/db/user/logout.proto",
				"process/db/user/signup.proto",
				"process/zone/sync.proto",
				"process/zone/enemy.proto",
				"process/world/player_route.proto",
				"process/lobby/start_game.proto",
				"process/lobby/end_game.proto",
				"process/lobby/enter.proto",
				"process/lobby/exit.proto"
			]
		}
	]
}